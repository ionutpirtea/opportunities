PORT=3000
# Every 15 minutes
SCHEDULE_CRON=*/15 * * * *
# Alert when abs percentage move >= threshold
ALERT_THRESHOLD_PCT=2
# Alert when abs percentage move over 2 business days >= threshold
ALERT_2DAY_THRESHOLD_PCT=3
# Optional timezone for cron expression
# TZ=Europe/Bucharest

# WhatsApp alerts via Twilio
WHATSAPP_ALERTS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Example: whatsapp:+14155238886 (Twilio sandbox sender)
TWILIO_WHATSAPP_FROM=
# Example: whatsapp:+407XXXXXXXX
TWILIO_WHATSAPP_TO=
# WhatsApp send mode: single digest message per run or one message per alert
WHATSAPP_DIGEST_MODE=single
# Safety limit so one run does not send too many WhatsApp messages
WHATSAPP_MAX_MESSAGES_PER_RUN=5
