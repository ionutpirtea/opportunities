<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <% 
      const hasNumericValue = (value) => value !== null && value !== undefined && value !== '' && Number.isFinite(Number(value));
      const fmtPrice = (value) => (hasNumericValue(value) ? Number(value).toFixed(2) : 'n/a');
      const fmtPct = (value) => (hasNumericValue(value) ? `${Number(value) >= 0 ? '+' : ''}${Number(value).toFixed(2)}%` : 'n/a');
    %>
    <main class="page">
      <nav class="top-nav">
        <a href="/report">Stock Report</a>
        <a href="/index-report">Index Report</a>
        <a href="/index-charts">Index Charts</a>
        <a href="/alerts-page" class="active">Alerts</a>
        <a href="/alerts-management">Alerts Management</a>
        <a href="/movers">Biggest Movers</a>
      </nav>

      <header class="hero">
        <div>
          <h1>Alerts</h1>
          <p>Stocks currently at least <strong><%= thresholdPct %>%</strong> below their 52-week high.</p>
          <p class="muted">Companies with negative operating cash flow in either of the last two quarters are excluded.</p>
        </div>
        <div class="hero-meta">
          <p><strong>Rule:</strong> current price <= <%= (100 - thresholdPct).toFixed(0) %>% of 52-week high</p>
          <p><strong>Drop Gate:</strong> 1D <= -<%= Number(oneDayDropPct).toFixed(1) %>% OR 2D <= -<%= Number(twoDayDropPct).toFixed(1) %>%</p>
          <p><strong>Min Market Cap:</strong> $<%= (Number(minMarketCap || 0) / 1000000000).toFixed(1) %>B</p>
          <form id="thresholdForm" class="filters" action="#">
            <label>
              52W Gap %
              <input id="thresholdPctInput" type="number" min="0.1" max="100" step="0.1" value="<%= thresholdPct %>" />
            </label>
            <label>
              1D Drop %
              <input id="threshold1DayInput" type="number" min="0.1" max="100" step="0.1" value="<%= oneDayDropPct %>" />
            </label>
            <label>
              2D Drop %
              <input id="threshold2DayInput" type="number" min="0.1" max="100" step="0.1" value="<%= twoDayDropPct %>" />
            </label>
            <button id="saveThresholdsBtn" type="submit">Save Rules</button>
          </form>
          <p id="thresholdStatus" class="muted"></p>
          <p><strong>Generated:</strong> <%= generatedAt %></p>
        </div>
      </header>

      <section class="panel">
        <h2>Relevant Stocks (<%= candidates.length %>)</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Ticker</th>
                <th>Description</th>
                <th>Current Price</th>
                <th>52W High</th>
                <th>Below 52W High %</th>
                <th>Today vs 1D</th>
                <th>Today vs 2D</th>
                <th>Reddit Interest</th>
                <th>Last Quote Time</th>
              </tr>
            </thead>
            <tbody>
              <% if (candidates.length === 0) { %>
              <tr>
                <td colspan="9">No stocks currently match the combined 52-week, market-cap, and drop-gate rules.</td>
              </tr>
              <% } %>
              <% candidates.forEach((row) => { %>
              <tr>
                <td><strong><%= row.ticker %></strong></td>
                <td><%= row.description || 'n/a' %></td>
                <td><%= fmtPrice(row.price) %></td>
                <td><%= fmtPrice(row.high52Week) %></td>
                <td class="down"><%= fmtPct(-row.pctBelow52WeekHigh) %></td>
                <td class="<%= Number.isFinite(row.pctVsOneBusinessDayAgo) && row.pctVsOneBusinessDayAgo <= -Number(oneDayDropPct) ? 'down' : '' %>"><%= fmtPct(row.pctVsOneBusinessDayAgo) %></td>
                <td class="<%= Number.isFinite(row.pctVsTwoBusinessDaysAgo) && row.pctVsTwoBusinessDaysAgo <= -Number(twoDayDropPct) ? 'down' : '' %>"><%= fmtPct(row.pctVsTwoBusinessDaysAgo) %></td>
                <td title="Posts scanned: <%= row.redditPostsScanned ?? 'n/a' %>"><%= Number.isFinite(row.redditMentions) ? row.redditMentions : 'n/a' %></td>
                <td><%= row.timestamp || 'n/a' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="panel">
        <h2>Recent Alert Events (<%= alerts.length %>)</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Timestamp</th>
                <th>Ticker</th>
                <th>Company</th>
                <th>52W High</th>
                <th>Current Price</th>
                <th>Gap to High %</th>
                <th>Reason</th>
              </tr>
            </thead>
            <tbody>
              <% if (alerts.length === 0) { %>
              <tr>
                <td colspan="7">No alert events yet.</td>
              </tr>
              <% } %>
              <% alerts.forEach((alert) => { %>
              <tr>
                <td><%= alert.timestamp %></td>
                <td><strong><%= alert.ticker %></strong></td>
                <td><%= descriptionMap?.[alert.ticker] || 'n/a' %></td>
                <td><%= fmtPrice(alert.old_price) %></td>
                <td><%= fmtPrice(alert.new_price) %></td>
                <td class="down"><%= fmtPct(alert.change_pct) %></td>
                <td><%= alert.reason %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
    <script>
      const thresholdForm = document.getElementById('thresholdForm');
      const thresholdStatus = document.getElementById('thresholdStatus');

      if (thresholdForm) {
        thresholdForm.addEventListener('submit', async (event) => {
          event.preventDefault();

          const saveBtn = document.getElementById('saveThresholdsBtn');
          const thresholdPctInput = document.getElementById('thresholdPctInput');
          const threshold1DayInput = document.getElementById('threshold1DayInput');
          const threshold2DayInput = document.getElementById('threshold2DayInput');

          const payload = {
            thresholdPct: Number(thresholdPctInput.value),
            alert1DayDropPct: Number(threshold1DayInput.value),
            alert2DayDropPct: Number(threshold2DayInput.value),
          };

          saveBtn.disabled = true;
          const previousText = saveBtn.textContent;
          saveBtn.textContent = 'Saving...';
          thresholdStatus.textContent = '';

          try {
            const res = await fetch('/config/thresholds', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });

            if (!res.ok) {
              const err = await res.json().catch(() => ({ error: 'Failed to save alert rules' }));
              throw new Error(err.error || 'Failed to save alert rules');
            }

            thresholdStatus.textContent = 'Alert rules updated.';
            setTimeout(() => location.reload(), 500);
          } catch (error) {
            thresholdStatus.textContent = error.message;
          } finally {
            saveBtn.disabled = false;
            saveBtn.textContent = previousText;
          }
        });
      }
    </script>
  </body>
</html>
